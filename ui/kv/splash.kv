<SplashScreen>:
    name: "splash"

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: app.theme_cls.backgroundColor

        MDWidget:

        MDLabel:
            text: "Auth App"
            font_style: "Headline"
            role: "large"
            halign: "center"
            adaptive_height: True

        MDLabel:
            text: "Autenticador 2FA"
            font_style: "Body"
            role: "medium"
            halign: "center"
            adaptive_height: True
            theme_text_color: "Custom"
            text_color: app.theme_cls.onSurfaceVariantColor

        MDWidget: